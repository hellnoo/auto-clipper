# LLM provider: ollama (free local), groq (free API), openrouter (paid API, best quality)
LLM_PROVIDER=ollama

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Groq (LLM_PROVIDER=groq). Get free key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (LLM_PROVIDER=openrouter). Get key: https://openrouter.ai/keys
# Recommended OPENROUTER_MODEL values:
#   anthropic/claude-sonnet-4.5   — best quality/$, strong viral judgment (default)
#   anthropic/claude-opus-4.7     — top tier, ~5x more expensive
#   openai/gpt-4o                 — great alternative
#   openai/gpt-4o-mini            — cheapest decent option (~$0.002/clip)
#   google/gemini-2.5-flash       — cheap + fast
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Whisper
# WHISPER_MODEL: tiny | base | small | medium | large-v3
#   For NVIDIA GPU users, 'medium' or 'large-v3' is recommended (huge accuracy bump).
#   For CPU-only, stick with 'small' or 'base'.
WHISPER_MODEL=small
# WHISPER_DEVICE: auto | cuda | cpu  (auto = try CUDA, fall back to CPU)
WHISPER_DEVICE=auto
# WHISPER_COMPUTE: leave blank to auto-pick (float16 on GPU, int8 on CPU)
WHISPER_COMPUTE=

# Paths
OUTPUT_DIR=output
DB_PATH=auto_clipper.db

# Download
VIDEO_QUALITY=720

# Clip constraints
CLIP_MIN_SEC=30
CLIP_MAX_SEC=60
CLIP_COUNT_MIN=3
CLIP_COUNT_MAX=7

# Speaker diarization (real per-speaker color in captions). Heavy: ~2GB
# pyannote install + needs an HF token + accepted model terms at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
DIARIZE_ENABLED=0
HF_TOKEN=

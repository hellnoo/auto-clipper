# LLM provider: ollama (default, free local) or groq (free tier API)
LLM_PROVIDER=ollama

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Groq (only used if LLM_PROVIDER=groq). Get free key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Whisper
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# Paths
OUTPUT_DIR=output
DB_PATH=auto_clipper.db

# Download
VIDEO_QUALITY=720

# Clip constraints
CLIP_MIN_SEC=30
CLIP_MAX_SEC=60
CLIP_COUNT_MIN=3
CLIP_COUNT_MAX=7
